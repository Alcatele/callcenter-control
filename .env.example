APP_NAME=Call Center Control
APP_ENV=production
APP_SECRET_KEY=change-this-secret-key
APP_PUBLIC_URL=http://localhost:8080

POSTGRES_DB=callcenter_control
POSTGRES_USER=callcenter
POSTGRES_PASSWORD=change-db-password
DATABASE_URL=postgresql+psycopg://callcenter:change-db-password@postgres:5432/callcenter_control

REDIS_URL=redis://redis:6379/0
JWT_EXPIRE_MINUTES=720

FUSIONPBX_DB_URL=postgresql+psycopg://fusionpbx_user:fusionpbx_password@fusionpbx-db-host:5432/fusionpbx
FREESWITCH_ESL_HOST=fusionpbx-host
FREESWITCH_ESL_PORT=8021
